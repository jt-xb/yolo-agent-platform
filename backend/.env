# DeepSeek API Key（从 https://platform.deepseek.com/ 获取）
LLM_API_KEY=sk-9c88e2418f2e49bda8721a13db2928e5

# LLM 配置
LLM_MODEL=deepseek-chat
LLM_API_BASE=https://api.deepseek.com/v1

# 服务器配置
HOST=0.0.0.0
PORT=8000
DEBUG=true

# MLU370（暂不使用）
USE_MLU=false
MLU_DEVICE_ID=0

# 数据库
