LOGS_DIR=./data/logs

# 训练配置
DEFAULT_YOLO_MODEL=yolov8n
DEFAULT_EPOCHS=100
DEFAULT_BATCH_SIZE=16
DEFAULT_IMAGE_SIZE=640

# 项目信息
PROJECT_NAME=YOLO-Agent-Platform
VERSION=0.1.0

# 国产硬件
USE_ASCEND=false
