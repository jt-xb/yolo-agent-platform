# YOLO自动化训推平台 - 环境配置
# 复制此文件为 backend/.env 并修改配置

# ===========================================
# 服务器配置
# ===========================================
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ===========================================
# 数据库配置
# ===========================================
# SQLite（默认）
# DATABASE_URL=sqlite:///./data/yolo_platform.db

# MySQL（使用已有容器）
# DATABASE_URL=mysql+pymysql://root:yolo_platform@mysql:3306/yolo_platform

# ===========================================
# LLM 配置（离线部署必须配置）
# ===========================================
LLM_MODEL=deepseek-chat
LLM_API_BASE=https://你的离线API地址/v1
LLM_API_KEY=你的离线API密钥

# ===========================================
# 训练配置
# ===========================================
# 默认 YOLO 模型
DEFAULT_YOLO_MODEL=yolov8n
DEFAULT_EPOCHS=100
DEFAULT_BATCH_SIZE=16
DEFAULT_IMAGE_SIZE=640

# ===========================================
# MLU370 配置（如有）
# ===========================================
# USE_MLU=true
# MLU_DEVICE_ID=0
