# YOLO Agent Platform — 离线环境配置
# 复制此文件为 backend/.env 并按需修改

# ========== LLM 配置（离线模式）==========
# 留空则使用规则引擎，不需联网
LLM_API_KEY=
LLM_MODEL=deepseek-chat
LLM_API_BASE=https://api.deepseek.com/v1

# ========== 数据目录 ==========
DATA_DIR=/opt/yolo-agent-platform/data

# ========== MLU370 加速（可选）==========
# 需安装寒武纪 Pytorch SDK 后启用
USE_MLU=false
MLU_DEVICE_ID=0

# ========== 服务器端口 ==========
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ========== 数据库 ==========
DATABASE_URL=sqlite:///./yolo_agent.db

# ========== 默认训练配置 ==========
DEFAULT_YOLO_MODEL=yolov8n
DEFAULT_EPOCHS=100
DEFAULT_BATCH_SIZE=16
DEFAULT_IMAGE_SIZE=640
