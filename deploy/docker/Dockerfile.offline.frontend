# Dockerfile.offline.frontend
# 离线版前端镜像（ARM aarch64），预构建好 dist 静态文件
# 使用 nginx 托管

FROM nginx:alpine

# 拷贝预构建的前端 dist 静态文件
COPY frontend/dist/ /usr/share/nginx/html/

# 拷贝 nginx 配置
COPY deploy/docker/nginx.deploy.conf /etc/nginx/conf.d/default.conf

# 健康检查
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD wget -q --spider http://localhost:80 || exit 1

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
